# ==========================================
# 🤖 AI PR Reviewer FastAPI Backend Config
# ==========================================

# Groq API Key for inference (Get from https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Default Groq Inference Model
# Recommended models: 
# - qwen/qwen3-32b
# - llama-3.3-70b-versatile (Higher Token-Per-Minute capacity)
# - llama-3.1-8b-instant (Ultra Fast)
GROQ_MODEL=qwen/qwen3-32b

# GitHub Personal Access Token (PAT) with 'repo' scope
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# GitHub Webhook Secret (random string for HMAC validation)
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here

# Path to coding standards markdown file
CODING_STANDARDS_PATH=./coding_standards.md

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Review Configuration
MAX_TOKENS_PER_REVIEW=4000
MIN_FILE_SIZE_FOR_REVIEW=10
